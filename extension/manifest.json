{
  "manifest_version": 3,
  "name": "Hunter System",
  "version": "1.0.0",
  "description": "Codeforces Hunter System holographic overlay.",
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "https://codeforces.com/*",
    "https://cf-hunter-system.onrender.com/*"
  ],
  "background": {
    "service_worker": "src/background/service_worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://codeforces.com/*"],
      "js": ["src/content/contentScript.js"]
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": false
  },
  "web_accessible_resources": [
    {
      "resources": ["src/*", "assets/*"],
      "matches": ["https://codeforces.com/*"]
    }
  ],
  "commands": {
    "toggle_system": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "Toggle Hunter System HUD"
    }
  }
}
